.webp"],specs:{},description:"Stock transfer press available for purchase.",country:"KOREA",tableSize:"2600x1500",qty:1,unit:"Unit"},{id:29,name:"FEEDER 1450",category:"feeder",type:"FEEDER",brand:"",capacity:"1450",image:"https://via.placeholder.com/300x200?text=FEEDER+1450",specs:{},description:"Stock feeder available for purchase.",qty:1,unit:"Unit"},{id:30,name:"SEYI MEKANIKAL PRESS 35 T",category:"press",type:"MEKANIKAL PRESS",brand:"SEYI",capacity:"35 T",image:"/seyi-press-35t.webp",images:["/seyi-press-35t.webp","/seyi-35t-2.webp"],videos:["/seyi-35t-video.mp4"],specs:{},description:"Stock mechanical press available for purchase.",qty:1,unit:"Unit"},{id:31,name:"SHIEH YIH MEKANIKAL PRESS 25 T",category:"press",type:"MEKANIKAL PRESS",brand:"SHIEH YIH",capacity:"25 T",image:"/seyi-press-25t.webp",images:["/seyi-press-25t.webp","/seyi-25t-2.webp","/seyi-25t-3.webp"],videos:["/seyi-25t-video1.mp4","/seyi-25t-video2.mp4"],specs:{},description:"Stock mechanical press available for purchase.",qty:1,unit:"Unit"},{id:32,name:"Smart AMRs (Autonomous Mobile Robot) Powered by AI",category:"robot",type:"AUTOMATION",brand:"Smart AMR",capacity:"",image:"/amr-1.jpeg",images:["/amr-1.jpeg","/amr-2.jpeg","/amr-3.jpeg","/amr-4.jpeg","/amr-5.jpeg","/amr-6.jpeg","/amr-7.jpeg"],specs:{Technology:"AI-Powered Autonomous Navigation",Features:"Real-time obstacle detection, Dynamic path adaptation",Applications:"Material handling, Internal logistics, Manufacturing automation"},description:"Why Your Business Should Embrace AMRs with AI Technology. In today's fast-paced and competitive industrial landscape, Autonomous Mobile Robots (AMRs) powered by Artificial Intelligence offer a smart, scalable solution for automating material handling and internal logistics. Unlike traditional AGVs, AMRs use AI-driven navigation to move freely, detect obstacles in real time, and adapt to dynamic environments without fixed paths. By integrating AMRs into your operations, your business can reduce labor 